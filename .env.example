# SKHY_ENV: local | ci | smoke (configs/environments/{name}.yaml 선택)
SKHY_ENV=local

# 로컬 PostgreSQL (docker-compose.yml 기본값과 일치)
SKHY_DATABASE_URL=postgresql+psycopg://skhy:skhy_local_dev@localhost:5432/skhy_research

# --- 조회 전용 API 키 (G-02 확인 전까지 UNKNOWN 취급, 값은 절대 커밋 금지) ---
# KRX Open API
KRX_API_KEY=
# 한국투자증권(KIS) Open API — 조회 전용 앱키/시크릿만 사용, 주문 권한 부여 금지
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# 토스증권 Open API
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# 비밀값 저장 방식: env | keychain (macOS Keychain 어댑터 사용 시 keychain)
SKHY_SECRET_BACKEND=env

# broker mode는 paper 외 값을 허용하지 않는다 (P0-03 부팅 게이트)
SKHY_BROKER_MODE=paper
